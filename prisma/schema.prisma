generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  /// Legacy/admin-only nullable contact field. Public Brain ID identity must not depend on email.
  email         String?   @unique
  /// Legacy/admin-only nullable credential hash. Public Brain ID auth does not use passwords.
  password      String?
  brainId       String?   @unique
  pseudonym     String?
  image         String?
  
  level         Int       @default(1)
  experience    Int       @default(0)
  rating        Int       @default(1000)
  bonuses       Int       @default(0)
  streakDays    Int       @default(0)
  lastPlayedAt  DateTime?

  role          String    @default("USER")
  createdAt     DateTime  @default(now())

  sessions      GameSession[]
  achievements  UserAchievement[]
  xpEvents      XpEvent[]
  feedback      Feedback[]
  messages      Message[]
  ideas         Idea[]
  ideaVotes     IdeaVote[]

  @@index([brainId])
  @@index([pseudonym])
  @@index([experience(sort: Desc)])
}

model XpEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  reason    String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model LeaderboardEntry {
  id        String   @id @default(cuid())
  pseudonym String   @unique
  xp        Int
  rank      Int
  updatedAt DateTime @updatedAt

  @@index([xp(sort: Desc)])
}

model Feedback {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String
  content       String
  trackingNum   String   @unique
  status        String   @default("new")
  adminResponse String?
  createdAt     DateTime @default(now())

  @@index([userId])
}

enum GameType {
  SCHULTE
  SCHULTE_GORBOV
  NUMERICAL_ANALYSIS
  LOGICAL_SEQUENCE
  SITUATIONAL_JUDGMENT
  STROOP
  N_BACK
  OBJECTIVE_FILTER
  PROFILING_RICE
  ANOMALY_DETECTOR
  DIALOGUE_2_1
  SPEED_TYPING
  SPATIAL_CONCEALMENT
  TOPOLOGY_MEMORY
  COLLISION_DETECTOR
  ASYNC_DISPATCHER
  NOISE_REDUCTION
  LANGUAGE_SCANNER
  DECRYPTOR
  REALITY_CHECK
}

model GameSession {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  gameType      GameType
  score         Int
  timeMs        Int
  isCompleted   Boolean  @default(false)
  
  metadata      Json     
  
  createdAt     DateTime @default(now())

  @@index([userId, isCompleted, createdAt])
  @@index([gameType, isCompleted, score])
}

model Idea {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  title         String
  description   String
  /// Canonical statuses: PENDING, IN_PROGRESS, DONE, REJECTED.
  /// Legacy open/planned/implemented/rejected values are normalized by API serializers.
  status        String   @default("PENDING")
  votes         IdeaVote[]
  createdAt     DateTime @default(now())
}

model IdeaVote {
  id        String   @id @default(cuid())
  ideaId    String
  userId    String
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([ideaId, userId])
}

model Achievement {
  id            String   @id @default(cuid())
  code          String   @unique
  title         String
  description   String
  iconUrl       String
  users         UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  user          User     @relation(fields: [userId], references: [id])
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  unlockedAt    DateTime @default(now())

  @@unique([userId, achievementId])
}

model Message {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  room      String   @default("global")
  createdAt DateTime @default(now())

  @@index([room, createdAt])
}

model SessionAnalyticsSummary {
  id                     String   @id @default(cuid())
  jobId                  String   @unique
  sourceSessionId        String
  moduleId               String
  category               String
  completed              Boolean
  createdAt              DateTime @default(now())
  eventCount             Int
  clickCount             Int
  durationMs             Int
  p50ReactionMs          Int
  p95ReactionMs          Int
  speedSlope             Float
  accuracy               Float
  fatigueIndex           Float
  engagementIndex        Float
  suspiciousPatternScore Float
  recommendationSignals  Json

  @@index([moduleId])
  @@index([category])
  @@index([createdAt])
  @@map("session_analytics_summaries")
}

model DailyPracticePlan {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  items     Json
  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@map("daily_practice_plans")
}
