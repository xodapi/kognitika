rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isVerified() {
      return isSignedIn();
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Feedback Collection
    match /feedback/{feedbackId} {
      allow list: if isAdmin();
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      allow create: if (
        isSignedIn() &&
        isValidId(feedbackId) &&
        isValidFeedback(request.resource.data) &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'new' &&
        request.resource.data.createdAt == request.time
      );

      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    function isValidFeedback(data) {
      return data.keys().hasAll(['userId', 'userName', 'brainLabel', 'content', 'type', 'createdAt', 'status']) &&
             data.keys().size() == 7 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.userName is string && data.userName.size() <= 100 &&
             data.brainLabel is string && data.brainLabel.size() <= 100 &&
             data.content is string && data.content.size() <= 5000 &&
             data.type in ['idea', 'bug', 'improvement', 'other'] &&
             data.status in ['new', 'reviewed', 'resolved'];
    }
  }
}
